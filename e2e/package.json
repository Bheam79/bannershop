{
  "name": "bannershop-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for BannerShop",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:a11y": "playwright test --project=chromium tests/accessibility.spec.ts",
    "visual": "playwright test --project=visual-regression",
    "visual:update": "playwright test --project=visual-regression --update-snapshots"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^24.12.2",
    "dotenv": "^16.4.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
